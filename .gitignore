# ── Virtual Environment ───────────────────────────────────────────────
# Never upload this — it's huge (100MB+) and machine-specific
.venv/
venv/
env/
ENV/

# ── Python Cache ──────────────────────────────────────────────────────
# Auto-generated by Python, not needed in repo
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Environment Variables ─────────────────────────────────────────────
# VERY IMPORTANT — never upload API keys!
.env
.env.local
.env.production

# ── PyCharm IDE Files ─────────────────────────────────────────────────
# Your editor settings, not needed by others
.idea/
*.iml
.idea_modules/

# ── VS Code ───────────────────────────────────────────────────────────
.vscode/

# ── OS Generated Files ────────────────────────────────────────────────
# Windows
Thumbs.db
desktop.ini

# Mac
.DS_Store
.AppleDouble

# ── Logs ─────────────────────────────────────────────────────────────
*.log
logs/

# ── Distribution / Build ─────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg

# ── Testing ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Jupyter Notebooks checkpoints ────────────────────────────────────
.ipynb_checkpoints/

# ── HuggingFace model cache (if you go back to flan-t5) ──────────────
# These are huge downloaded model files
*.safetensors
*.bin
models/